{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["bun-types"],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@aria/engine/*": ["packages/runtime/src/*", "src/engine/*"],
      "@aria/connectors/*": ["packages/connectors/src/*", "src/connectors/*"],
      "@aria/shared/*": ["packages/shared-types/src/*", "src/shared/*"],
      "@aria/cli/*": ["packages/cli/src/*", "src/cli/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx"
  ],
  "exclude": ["node_modules", "dist"]
}
