{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["bun-types"],
    "ignoreDeprecations": "6.0",
    "paths": {
      "@aria/cli/*": ["./packages/cli/src/*"],
      "@aria/protocol": ["./packages/protocol/src/index.ts"],
      "@aria/protocol/*": ["./packages/protocol/src/*"],
      "@aria/runtime": ["./packages/runtime/src/index.ts"],
      "@aria/runtime/*": ["./packages/runtime/src/*"],
      "aria-server": ["./apps/aria-server/src/index.ts"],
      "aria-server/*": ["./apps/aria-server/src/*"],
      "aria-desktop": ["./apps/aria-desktop/src/index.ts"],
      "aria-desktop/*": ["./apps/aria-desktop/src/*"],
      "@aria/server": ["./packages/server/src/index.ts"],
      "@aria/server/*": ["./packages/server/src/*"],
      "@aria/access-client": ["./packages/access-client/src/index.ts"],
      "@aria/access-client/*": ["./packages/access-client/src/*"],
      "@aria/jobs": ["./packages/jobs/src/index.ts"],
      "@aria/jobs/*": ["./packages/jobs/src/*"],
      "@aria/work": ["./packages/work/src/index.ts"],
      "@aria/work/*": ["./packages/work/src/*"],
      "@aria/handoff": ["./packages/handoff/src/index.ts"],
      "@aria/handoff/*": ["./packages/handoff/src/*"],
      "@aria/harness": ["./packages/harness/src/index.ts"],
      "@aria/harness/*": ["./packages/harness/src/*"],
      "@aria/agent": ["./packages/agent/src/index.ts"],
      "@aria/agent/*": ["./packages/agent/src/*"],
      "@aria/automation": ["./packages/automation/src/index.ts"],
      "@aria/automation/*": ["./packages/automation/src/*"],
      "@aria/connectors": ["./packages/connectors/src/index.ts"],
      "@aria/connectors/*": ["./packages/connectors/src/*"],
      "@aria/console": ["./packages/console/src/index.ts"],
      "@aria/console/*": ["./packages/console/src/*"],
      "@aria/gateway": ["./packages/gateway/src/index.ts"],
      "@aria/gateway/*": ["./packages/gateway/src/*"],
      "@aria/audit": ["./packages/audit/src/index.ts"],
      "@aria/audit/*": ["./packages/audit/src/*"],
      "@aria/memory": ["./packages/memory/src/index.ts"],
      "@aria/memory/*": ["./packages/memory/src/*"],
      "@aria/policy": ["./packages/policy/src/index.ts"],
      "@aria/policy/*": ["./packages/policy/src/*"],
      "@aria/prompt": ["./packages/prompt/src/index.ts"],
      "@aria/prompt/*": ["./packages/prompt/src/*"],
      "@aria/persistence": ["./packages/persistence/src/index.ts"],
      "@aria/persistence/*": ["./packages/persistence/src/*"],
      "@aria/tools": ["./packages/tools/src/index.ts"],
      "@aria/tools/*": ["./packages/tools/src/*"],
      "@aria/workspaces": ["./packages/workspaces/src/index.ts"],
      "@aria/workspaces/*": ["./packages/workspaces/src/*"]
    }
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "tests/**/*.ts",
    "scripts/**/*.ts",
    "services/**/*.ts",
    "services/**/*.tsx"
  ],
  "exclude": ["node_modules", "dist"]
}
