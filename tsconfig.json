{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["bun-types"],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@aria/engine/*": ["packages/runtime/src/*"],
      "@aria/connectors/*": ["packages/connectors/src/*"],
      "@aria/shared/*": ["packages/shared-types/src/*"],
      "@aria/cli/*": ["packages/cli/src/*"],
      "@aria/protocol": ["packages/protocol/src/index.ts"],
      "@aria/protocol/*": ["packages/protocol/src/*"],
      "@aria/runtime": ["packages/runtime/src/index.ts"],
      "@aria/runtime/*": ["packages/runtime/src/*"],
      "@aria/server": ["packages/server/src/index.ts"],
      "@aria/server/*": ["packages/server/src/*"],
      "@aria/access-client": ["packages/access-client/src/index.ts"],
      "@aria/access-client/*": ["packages/access-client/src/*"],
      "@aria/desktop-bridge": ["packages/desktop-bridge/src/index.ts"],
      "@aria/desktop-bridge/*": ["packages/desktop-bridge/src/*"],
      "@aria/desktop-git": ["packages/desktop-git/src/index.ts"],
      "@aria/desktop-git/*": ["packages/desktop-git/src/*"],
      "@aria/agents-coding": ["packages/agents-coding/src/index.ts"],
      "@aria/agents-coding/*": ["packages/agents-coding/src/*"],
      "@aria/jobs": ["packages/jobs/src/index.ts"],
      "@aria/jobs/*": ["packages/jobs/src/*"],
      "@aria/projects": ["packages/projects/src/index.ts"],
      "@aria/projects/*": ["packages/projects/src/*"],
      "@aria/projects-engine": ["packages/projects-engine/src/index.ts"],
      "@aria/projects-engine/*": ["packages/projects-engine/src/*"],
      "@aria/handoff": ["packages/handoff/src/index.ts"],
      "@aria/handoff/*": ["packages/handoff/src/*"],
      "@aria/agent-aria": ["packages/agent-aria/src/index.ts"],
      "@aria/agent-aria/*": ["packages/agent-aria/src/*"],
      "@aria/automation": ["packages/automation/src/index.ts"],
      "@aria/automation/*": ["packages/automation/src/*"],
      "@aria/connectors-im": ["packages/connectors-im/src/index.ts"],
      "@aria/connectors-im/*": ["packages/connectors-im/src/*"],
      "@aria/console": ["packages/console/src/index.ts"],
      "@aria/console/*": ["packages/console/src/*"],
      "@aria/gateway": ["packages/gateway/src/index.ts"],
      "@aria/gateway/*": ["packages/gateway/src/*"],
      "@aria/memory": ["packages/memory/src/index.ts"],
      "@aria/memory/*": ["packages/memory/src/*"],
      "@aria/workspaces": ["packages/workspaces/src/index.ts"],
      "@aria/workspaces/*": ["packages/workspaces/src/*"],
      "@aria/providers-aria": ["packages/providers-aria/src/index.ts"],
      "@aria/providers-aria/*": ["packages/providers-aria/src/*"],
      "@aria/providers-codex": ["packages/providers-codex/src/index.ts"],
      "@aria/providers-codex/*": ["packages/providers-codex/src/*"],
      "@aria/providers-claude-code": ["packages/providers-claude-code/src/index.ts"],
      "@aria/providers-claude-code/*": ["packages/providers-claude-code/src/*"],
      "@aria/providers-opencode": ["packages/providers-opencode/src/index.ts"],
      "@aria/providers-opencode/*": ["packages/providers-opencode/src/*"],
      "@aria/ui": ["packages/ui/src/index.ts"],
      "@aria/ui/*": ["packages/ui/src/*"]
    }
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "tests/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
