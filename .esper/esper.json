{
  "schema_version": 1,
  "backlog_mode": "local",
  "spec_root": "specs",
  "commands": {
    "test": "bun test",
    "lint": "bun run lint",
    "typecheck": "bun run typecheck",
    "dev": "bun run dev",
    "build": "bun run build"
  },
  "workflow_defaults": {
    "work_mode": "atom",
    "commit_granularity": "per-increment",
    "pr_policy": "explicit-only",
    "validation_mode": "blocking",
    "spec_sync": "proactive"
  }
}
